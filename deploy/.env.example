# Copy to `.env` in this deploy/ folder on the server and adjust.
# Compose automatically reads this file for variable substitution.

# Image tag to deploy (matches a tag pushed by the GitHub Actions workflow):
#   latest        -> newest build from main
#   sha-<commit>  -> a specific commit
#   1.2.3         -> a released version
IMAGE_TAG=latest

# Browser origin allowed to call the API directly (the frontend domain).
CORS_ORIGIN=https://new.voterun.app

# Secret used to sign authentication tokens (JWT). REQUIRED in production.
# Generate a strong value, e.g.:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Grafana admin password (monitoring at grafana.voterun.app). REQUIRED.
# Generate a strong value, e.g.:  openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password
